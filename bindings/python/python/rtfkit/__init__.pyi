"""Type stubs for rtfkit."""

from typing import Optional, Sequence

__version__: str

# =============================================================================
# Exceptions
# =============================================================================

class RtfkitError(Exception):
    """Base exception for all rtfkit errors."""
    ...

class ParseError(RtfkitError):
    """RTF parsing failed."""
    ...

class ReportError(RtfkitError):
    """Report generation failed."""
    ...

class HtmlWriterError(RtfkitError):
    """HTML generation failed."""
    ...

class DocxWriterError(RtfkitError):
    """DOCX generation failed."""
    ...

class PdfRenderError(RtfkitError):
    """PDF rendering failed."""
    ...

