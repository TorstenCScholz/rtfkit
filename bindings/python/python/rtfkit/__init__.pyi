class ParserLimits:
    def __init__(
        self,
        *,
        max_input_bytes: Optional[int] = None,
        max_group_depth: Optional[int] = None,
        max_warning_count: Optional[int] = None,
        max_rows_per_table: Optional[int] = None,
        max_cells_per_row: Optional[int] = None,
        max_merge_span: Optional[int] = None,
        max_image_bytes_total: Optional[int] = None,
    ) -> None: ...
    @staticmethod
    def unlimited() -> ParserLimits: ...
    @property
    def max_input_bytes(self) -> int: ...
    @property
    def max_group_depth(self) -> int: ...
    @property
    def max_warning_count(self) -> int: ...
    @property
    def max_rows_per_table(self) -> int: ...
    @property
    def max_cells_per_row(self) -> int: ...
    @property
    def max_merge_span(self) -> int: ...
    @property
    def max_image_bytes_total(self) -> int: ...

